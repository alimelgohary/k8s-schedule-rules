apiVersion: v1
kind: Pod
metadata:
  name: pod-with-tol1
  labels:
    app.kubernetes.io/name: pod-with-tol1
spec:
  tolerations:
  - key: test
    operator: Equal
    value: 'true'
    effect: NoSchedule
  containers:
  - name: pod-with-tol1
    image: nginx:latest
    resources:
      limits:
        memory: "128Mi"
        cpu: "500m"
      requests:
        memory: "100Mi"
        cpu: "300m"
    ports:
      - containerPort: 80
